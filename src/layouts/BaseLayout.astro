---
import Footer from "../components/Footer.astro";

const { title = "Welcome" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style>
      :root {
        font-family: Arial, Helvetica, sans-serif;
      }

      html,
      body {
        margin: 0;
        min-height: 100%;
      }

      body {
        min-height: 100vh;
      }

      main {
        min-height: 100vh;
        padding-bottom: 90px;
        box-sizing: border-box;
      }
    </style>
  </head>
  <body>
    <main>
      <slot />
    </main>

    <Footer />
  </body>
</html>
